generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model PurchaseOrder {
  id            Int      @id @default(autoincrement())

  orderNumber   String   @unique

  createdAt     DateTime @default(now())

  buyerId       Int
  buyer         Buyer   @relation(fields: [buyerId], references: [id])

  supplierId    Int
  supplier       Supplier @relation(fields: [supplierId], references: [id])

  totalAmount   Float?

  items         PurchaseItem[]

  @@index([supplierId])
  @@index([buyerId])
  @@index([createdAt])
}

model PurchaseItem {
  id             Int      @id @default(autoincrement())

  purchaseOrderId Int
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  productId      Int
  product        Product @relation(fields: [productId], references: [id])

  quantity       Float

  unit String? 
  Measure String?

  unitPrice      Float
  totalPrice     Float

  fraudAnalysis  FraudAnalysis?

  createdAt      DateTime @default(now())
  @@unique([purchaseOrderId, productId])

  @@index([productId])
  @@index([purchaseOrderId])
  @@index([createdAt])
}

model Product {
  id          Int      @id @default(autoincrement())

  name        String

  StandardUnit String?
  StandardMeasure String?

  items       PurchaseItem[]
}

model Supplier {
  id          Int      @id @default(autoincrement())

  name        String

  orders      PurchaseOrder[]
}


model Buyer {
  id          Int      @id @default(autoincrement())

  name        String

  orders      PurchaseOrder[]
}

model FraudAnalysis {
  id               Int      @id @default(autoincrement())

  purchaseItemId   Int      @unique
  purchaseItem     PurchaseItem @relation(fields: [purchaseItemId], references: [id])

  fraudScore       Float

  suspicious       Boolean

  reason           String?

  createdAt        DateTime @default(now())

  @@index([suspicious])
  @@index([createdAt])
}

